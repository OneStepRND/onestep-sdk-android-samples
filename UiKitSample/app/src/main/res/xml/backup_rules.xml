<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- With <include> present, only the listed paths are backed up; everything else (cache,
         databases, etc.) is excluded by omission, so no <exclude> entries are needed. -->
    <include domain="sharedpref" path="*" />
    <include domain="file" path="files/" />
</full-backup-content>
